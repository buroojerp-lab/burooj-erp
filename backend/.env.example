# ============================================================
# BUROOJ ERP - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=burooj_erp
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES=30d

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=burooj-erp-files

# WhatsApp Cloud API
WA_API_VERSION=v18.0
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Email (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# OCR (Tesseract)
OCR_LANGUAGE=eng

# App
COMPANY_NAME=Burooj Heights
COMPANY_PHONE=+923001234567
COMPANY_EMAIL=info@buroojheights.com
FRONTEND_URL=http://localhost:3000
